{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "strict": false,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "../dist/backend",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main.ts", "src/lib/**/*.ts"]
}
