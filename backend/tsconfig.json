{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "lib": ["es2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "../dist/backend",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
